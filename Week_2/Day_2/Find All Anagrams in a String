class Solution {
public:
    vector<int> findAnagrams(string s, string p) {
        vector<int> res;
        if(s.size()<p.size()) return res;
        vector<int> pi(26,0) ,si(26,0);
        for(char c: p) pi[c-'a']++;
        for(int i=0;i<s.size();i++){
            si[s[i]-'a']++;
            if(i>=p.size()) si[s[i-p.size()]-'a']--;
            if(si==pi) res.push_back(i-p.size()+1);
        }
        return res;
    }
};
