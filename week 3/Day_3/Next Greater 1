class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {        
        stack<int>stk;
        unordered_map<int,int> nextgreater;
        reverse(nums2.begin(),nums2.end());
        for(int currentnum : nums2){
            while(!stk.empty()&&stk.top()<currentnum){
                stk.pop();
            }
            if(!stk.empty()){
                nextgreater[currentnum]=stk.top();
            }
            stk.push(currentnum);

        }
        vector<int>result;
        for(int num : nums1){
            if(nextgreater.find(num)!=nextgreater.end()){
                result.push_back(nextgreater[num]);
            }
            else{
                result.push_back(-1);
            }
        }
        return result;

    }
};
